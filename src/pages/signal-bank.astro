---
const signalFiles = import.meta.glob('../../signals/**/*.md', { eager: true });

const signals = Object.entries(signalFiles)
  .map(([path, mod]) => {
    const fm = mod.frontmatter || {};

    return {
      path,
      Content: mod.Content,
      title: fm.title || path.split('/').pop(),
      issue: fm.issue || '000',
      issueTitle: fm.issue_title || 'Unsorted',
      rubric: fm.rubric || 'Signal Bank',
      status: fm.status || 'candidate',
      score: fm.ai_score || 0,
      verdict: fm.ai_verdict || '',
      url: fm.url || '',
      source: fm.source || '',
      date: fm.date || '',
    };
  })
  .sort((a, b) => {
    if (a.issue !== b.issue) return a.issue.localeCompare(b.issue);
    return Number(b.score) - Number(a.score);
  });
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <title>NOOSPHERE — Signal Bank</title>
    <meta name="viewport" content="width=device-width" />
    <style>
      body { margin:0; padding:48px; background:#07070b; color:#f2f2f2; font-family:system-ui,sans-serif; }
      main { max-width:1180px; margin:0 auto; }
      nav { margin-bottom:40px; }
      nav a { color:#8ee6ff; text-decoration:none; font-size:14px; text-transform:uppercase; letter-spacing:.1em; }
      h1 { font-size:clamp(42px,8vw,96px); letter-spacing:-0.08em; margin:0 0 8px; }
      .lede { color:#b9b9c8; max-width:760px; font-size:20px; line-height:1.5; margin-bottom:48px; }
      .grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(360px,1fr)); gap:24px; }
      article { border:1px solid #26263a; background:linear-gradient(180deg,#11111a,#0b0b11); padding:24px; border-radius:18px; }
      .meta { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:14px; font-size:12px; text-transform:uppercase; letter-spacing:.08em; color:#8ee6ff; }
      .pill { border:1px solid #33334a; border-radius:999px; padding:4px 8px; }
      .issue { color:#ffffff; border-color:#8ee6ff; }
      .status { color:#ff4d5d; border-color:#ff4d5d; }
      h2 { font-size:24px; line-height:1.1; margin:0 0 12px; }
      .source { color:#b9b9c8; font-size:14px; margin-bottom:18px; }
      .content { color:#dedee8; line-height:1.55; font-size:15px; }
      .content h1 { font-size:22px; letter-spacing:0; margin:16px 0; }
      .content h2 { font-size:16px; color:#8ee6ff; margin-top:24px; text-transform:uppercase; letter-spacing:.08em; }
      .content p { margin:0 0 12px; }
      .content a, a { color:#8ee6ff; }
      hr { border:0; border-top:1px solid #2a2a3a; margin:20px 0; }
    </style>
  </head>
  <body>
    <main>
      <nav>
        <a href="/noosphere/">← Current issue cover</a>
      </nav>

      <h1>SIGNAL BANK</h1>
      <p class="lede">
        Черновой архив Нооскопа: карточки материалов, распределённые по будущим выпускам.
        Это ещё не публикация, а редакционная руда.
      </p>

      <div class="grid">
        {signals.map((item) => (
          <article>
            <div class="meta">
              <span class="pill issue">ISSUE {item.issue}</span>
              <span class="pill">{item.issueTitle}</span>
              <span class="pill">{item.rubric}</span>
              <span class="pill status">{item.status}</span>
              {item.verdict && <span class="pill">{item.verdict}</span>}
              {item.score > 0 && <span class="pill">{item.score}</span>}
            </div>

            <h2>{item.title}</h2>

            <div class="source">
              {item.source} · {item.date}
              {item.url && <> · <a href={item.url}>source</a></>}
            </div>

            <div class="content">
              <item.Content />
            </div>
          </article>
        ))}
      </div>
    </main>
  </body>
</html>
