---
const signalFiles = import.meta.glob('../../signals/**/*.md', { eager: true });

const signals = Object.entries(signalFiles)
  .map(([path, mod]) => {
    const frontmatter = mod.frontmatter || {};
    const issue = frontmatter.issue || '000';

    return {
      path,
      title: frontmatter.title || path.split('/').pop(),
      issue,
      issueTitle: frontmatter.issue_title || 'Unsorted',
      status: frontmatter.status || 'candidate',
      score: frontmatter.ai_score || 0,
      url: frontmatter.url || '',
    };
  })
  .sort((a, b) => {
    if (a.issue !== b.issue) return a.issue.localeCompare(b.issue);
    return Number(b.score) - Number(a.score);
  });

const grouped = signals.reduce((acc, signal) => {
  const key = `${signal.issue} — ${signal.issueTitle}`;
  acc[key] ||= [];
  acc[key].push(signal);
  return acc;
}, {});
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <title>NOOSPHERE — Signal Bank</title>
    <meta name="viewport" content="width=device-width" />
    <style>
      body {
        margin: 0;
        padding: 48px;
        background: #07070b;
        color: #f2f2f2;
        font-family: system-ui, sans-serif;
      }

      main {
        max-width: 1100px;
        margin: 0 auto;
      }

      h1 {
        font-size: clamp(42px, 8vw, 96px);
        letter-spacing: -0.08em;
        margin: 0 0 8px;
      }

      .lede {
        color: #b9b9c8;
        max-width: 760px;
        font-size: 20px;
        line-height: 1.5;
        margin-bottom: 48px;
      }

      section {
        border-top: 1px solid #333344;
        padding: 28px 0;
      }

      h2 {
        color: #8ee6ff;
        font-size: 18px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0 0 18px;
      }

      article {
        display: grid;
        grid-template-columns: 120px 1fr auto;
        gap: 16px;
        padding: 14px 0;
        border-top: 1px solid #1b1b28;
      }

      .status {
        color: #ff4d5d;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .title {
        font-size: 18px;
      }

      .score {
        color: #b9b9c8;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover {
        color: #8ee6ff;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>NOOSPHERE</h1>
      <p class="lede">
        Signal Bank v0.1. Черновой архив Нооскопа: найденные материалы,
        распределённые по будущим выпускам. Это ещё не публикация, а редакционная руда.
      </p>

      {Object.entries(grouped).map(([issue, items]) => (
        <section>
          <h2>{issue}</h2>

          {items.map((item) => (
            <article>
              <div class="status">{item.status}</div>
              <div class="title">
                {item.url ? <a href={item.url}>{item.title}</a> : item.title}
              </div>
              <div class="score">{item.score}</div>
            </article>
          ))}
        </section>
      ))}
    </main>
  </body>
</html>
